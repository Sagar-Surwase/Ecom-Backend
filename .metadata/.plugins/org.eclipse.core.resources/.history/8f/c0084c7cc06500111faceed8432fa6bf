package com.cjc.laptophub.app.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.cjc.laptophub.app.model.User;
import com.cjc.laptophub.app.service.UserServiceI;

import lombok.extern.slf4j.Slf4j;

@Slf4j
@RestController
@RequestMapping("/user")
public class UserController 
{

	@Autowired
	UserServiceI usi;
	
	
	@PostMapping("/register")
	public ResponseEntity<User> saveUserData(@RequestBody User user)
	{
		log.info("User registration request received.");
		
		User savedUser = usi.saveUserData(user);
		
		return new ResponseEntity<User>(savedUser, HttpStatus.CREATED);
	}
	
	
	
	@GetMapping("/login/{email}/{password}")
	public ResponseEntity<?> loginUser(@PathVariable String email, @PathVariable String password)
	{
		log.info("User login request received.");
				
		User dbUser = usi.getUserByEmailAndPassword(email, password);
		
		
		log.info(email);
		
		if(dbUser!=null)
		{
			//For Admin Login...
			
			if(dbUser.getEmail().equals("admin") && dbUser.getPassword().equals("admin") && dbUser.getRole().equals("admin"))			
			{
		        log.info("Admin logged in successfully.");
				
				return new ResponseEntity<>(dbUser, HttpStatus.OK);
			}
			
			//For Customer Login...
			
			else																					
			{
		        log.info("Customer logged in successfully.");
				
				return new ResponseEntity<>(dbUser, HttpStatus.OK);
			}	

		}
		else
		{
		    log.warn("Invalid login credentials.");
		    
			return new ResponseEntity<>("Invalid email or password.", HttpStatus.UNAUTHORIZED);
		}
	
	}
	
	
	
	@GetMapping("/getUser/{id}")
	public ResponseEntity<?> getUserData(@PathVariable int id)
	{
		User dbUser = usi.getUserData(id);
		
		if(dbUser!=null)
		{
			return new ResponseEntity<>(dbUser, HttpStatus.OK);
		}
		else
		{
			return new ResponseEntity<>("User is not Found", HttpStatus.NOT_FOUND);
		}
	}
	
	
	
	
	
	@DeleteMapping("/deleteUser/{id}")
	public ResponseEntity<?> deleteUserData(@PathVariable int id)
	{
		String msg = usi.deleteUserData(id);
		
		if(msg!=null)
		{
			return new ResponseEntity<>(msg, HttpStatus.OK);
		}
		else
		{
			return new ResponseEntity<>("User not found.", HttpStatus.NOT_FOUND);
		}
		
	}
	
	
	@PutMapping("/updateUser/{id}")
	public ResponseEntity<?> updateUserData(@PathVariable int id, @RequestBody User user)
	{
		User updatedUser = usi.updateUserData(id, user);
		
		if(updatedUser!=null)
		{
			return new ResponseEntity<>(updatedUser, HttpStatus.CREATED);
		}
		else
		{
			return new ResponseEntity<>("User is not Found", HttpStatus.NOT_FOUND);
		}
	}
	
	
}
